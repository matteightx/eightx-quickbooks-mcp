# QuickBooks Online OAuth2 — from https://developer.intuit.com → My Apps → your app → Keys & OAuth
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=production

# Public redirect URI. Must match exactly what you registered on the Intuit app.
# On Railway: https://<your-service>.up.railway.app/oauth/callback
# Local dev:  http://localhost:8080/oauth/callback
QBO_REDIRECT_URI=

# HTTP mode (Railway sets this automatically). Unset = stdio mode (local Claude Code).
PORT=

# Where per-client token files live. On Railway, point this at a mounted volume
# so refresh-token rotation survives redeploys — e.g. /data/tokens.
QBO_TOKENS_DIR=./tokens
